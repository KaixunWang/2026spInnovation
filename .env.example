# === API keys ===
# Fill in ONLY the providers you have access to. The framework is
# provider-agnostic: at minimum you need 2 different families (one for
# generation, one for judging, to avoid self-bias).

# OpenAI (gpt-4o, gpt-4o-mini, text-embedding-3-large, ...)
OPENAI_API_KEY=
# Custom base URL for OpenAI-compatible proxies (NO /chat/completions suffix).
# Example: proxy exposes https://globalai.vip/v1/chat/completions  →  set:
#   OPENAI_BASE_URL=https://globalai.vip/v1
OPENAI_BASE_URL=

# Anthropic (claude-3-5-sonnet, claude-3-5-haiku)
ANTHROPIC_API_KEY=

# DeepSeek (本项目统一用 deepseek-v4-pro)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Alibaba DashScope (qwen3.5-flash, qwen-max, …). Used only for provider=dashscope;
# requests do NOT fall back to OPENAI_BASE_URL. Set BASE_URL to your relay if needed.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Zhipu (glm-4-plus)
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Moonshot (moonshot-v1-32k)
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# === Runtime knobs ===
# Mechanism arm only: overrides experiment.yaml mechanism.generator_model (default: gen_qwen35_flash).
# MECHANISM_GENERATOR=

# Maximum daily spend guardrail (USD). Script will abort if exceeded.
DAILY_BUDGET_USD=20
# Cache directory (default: .cache/)
CACHE_DIR=.cache
# HuggingFace cache (for NLI / sentiment / SBERT models)
HF_HOME=.cache/hf
# Local metrics: NLI / sentiment pipelines, SBERT embeddings, GPT-2 PPL.
# auto = use GPU if torch.cuda.is_available() (requires CUDA build of torch).
INNOVATION_METRICS_DEVICE=auto
# After models are cached under HF_HOME, set to 1 to avoid Hub API calls during load (e.g. HF 500).
# INNOVATION_HF_LOCAL_ONLY=1
